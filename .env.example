# GitLab CE（compose profile: gitlab）用
# コピーして .env として保存:  cp .env.example .env
#
# ルートのパスワード（ブラウザログイン・初回シードの API 用）
# シングルクォートを含めないでください（Omnibus 設定の都合）。
GITLAB_ROOT_PASSWORD=ChangeMe_Exercise_Lab_2025

# 演習用に固定する Personal Access Token（scripts/seed_gitlab_project.sh が作成）
# 閉域ラボ専用。他環境では必ず変更してください。
GITLAB_SEED_PAT=exercise-gitlab-seed-token

# GitLab を同時に起動する場合（start_exercise_lab.sh でも設定済み）
# COMPOSE_PROFILES=gitlab
